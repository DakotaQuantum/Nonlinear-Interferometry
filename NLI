#Define useful functions for converting between wavelength and angular frequency

#this function takes angular frequency (value) in rad/sec and returns a new value of the corresponding wavelength in micrometers
def wavelength(angular_frequency, speed_of_light = c, two_pi = two_pi):
    return two_pi * speed_of_light / angular_frequency 

#this function takes wavelength in micrometers and converts it to the corresponding angular frequency value in rad/sec
def angular_frequency(wavelength, speed_of_light = c, two_pi = two_pi):
    return two_pi * speed_of_light / wavelength 

#define a function that normalizes a function f(x) such that the definite integral 
#over its domain is 1 
#accepts x (1D array-like) and f_of_x (1D array-like)
#and returns f_of_x multiplied by a normalization factor
def normalize(x, f_of_x):
    a = x[0] 
    b = x[-1] 
    n = len(x)
    dx = (b - a) / n
    integral = 0
    for j in range(1, n):
        f_of_x_j = f_of_x[j] 
        integral += abs(f_of_x_j) * dx 
    normalization_factor = integral ** (-1) 
    return f_of_x * normalization_factor 

#define a function that normalizes |f(x)|^2 
#accepts x (1D array-like) and f_of_x (1D array-like)
#and returns f_of_x multiplied by normalization factor
def normalize_square(x, f_of_x):
    a = x[0] 
    b = x[-1]
    n = len(x)
    dx = (b - a) / n
    integral = 0
    for j in range(1, n):
        f_of_x_j = f_of_x[j] 
        integral += abs(f_of_x_j)**2 * dx 
    normalization_factor = integral ** (-1/2) 
    return f_of_x * normalization_factor 

#define a function that normalizes |f(x,y)|^2 
#this function takes the inputs {x,y} (1D array-like)
#and a f_of_x_y (2D array-like) which is assumed to be generated from some function f(x,y)
#and returns f_of_x_y multiplied by a normalization factor
def normalize_2D(x, y, f_of_x_y):
    a = x[0] 
    b = x[-1]
    d = y[0] 
    e = y[-1]
    n = len(x)
    m = len(y) 
    dx = (b - a) / n
    dy = (e - d) / m
    integral = 0
    for j in range(0, n):
        for k in range(0, m):
            f_of_x_y_j_k = f_of_x_y[j,k]
            integral += abs(f_of_x_y_j_k)**2 * dx * dy
    normalization_factor = integral ** (-1/2) 
    return f_of_x_y * normalization_factor

