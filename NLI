#a function that calculates the singular value decomposition of a joint spectral ampltude
#it takes l_1 and l_2 (1D array-like) and JSA (2D array-like) 
#as well as plotting which is a string that is either 'true' or 'false'
#and loss_in_dB corresponding to the possibility of loss which will be calculated later
def get_modes(l_1, l_2, JSA, plotting, loss_in_dB):
    U,s,V = np.linalg.svd(JSA) 
    #U = matrix whose columns are the signal mode arrays
    #s = matrix whose diagonal elements are the amplitudes for the modes
    #V = matrix whose rows are the idler mode arrays 
    #s_norm = normalized amplitudes
    #K = Schmidt number 
    s_norm = s / np.sqrt(sum(s**2)) 
    K = 1 / sum(abs(s_norm)**4) 
    #the jth signal mode is the jth column of U, i.e. U[:,j]
    #the jth idler mode is the jth row of V, i.e. V[j,:] 
    signal_modes = lambda j: U[:,j] 
    idler_modes = lambda j: V[j,:]  
    if plotting == 'true' and loss_in_dB in [0,1,3]:
        for j in range(0,2):
            fig, ax = plt.subplots()
            ax.plot(l_1*1000, abs(signal_modes(j))**2 / np.max(abs(signal_modes(j))**2), label = rf'$|\psi^{{(s)}}_{j}|^2\,$'+ rf'$({np.round(loss_in_dB,2)}\;\mathrm{{dB}})$', linewidth = 2) 
            ax.plot(l_2*1000, abs(idler_modes(j))**2 / np.max(abs(idler_modes(j))**2), label = rf'$|\phi^{{(i)}}_{j}|^2\,$'+ rf'$({np.round(loss_in_dB,2)}\;\mathrm{{dB}})$', linewidth = 2) 
            ax.set_xlabel(r'$\lambda~\mathrm{(nm)}$', fontsize = 24)
            ax.set_ylabel(r'$\mathrm{Intensity}~\mathrm{(a.u.)}$', fontsize = 24) 
            ax.tick_params(axis='x', labelsize = 20)
            ax.tick_params(axis='y', labelsize = 20)
            ax.grid() 
            plt.legend(fontsize = 16, loc = (0.6, 0.7))  
            if savefigures == 'true':
                plt.savefig(f'{grid_or_HDE}_SVD_mode_{j}_{loss_in_dB}_dB_loss.svg')
            plt.show() 
    return [signal_modes, idler_modes, K, s_norm]

#these functions s_omega and s_wavelength convert units involving spacing or distance (bandwidth, etc) 
#between wavelength and frequency units
#they accept a spacing (value) in wavelength (angular frequency) and a central point l_0 (value) around which to calculate
#and return the corresponding spacing value in angular frequency (wavelength)
def s_omega(s_wavelength, l_0):
    a = angular_frequency(l_0) 
    b = angular_frequency(l_0 + s_wavelength) 
    return abs(b - a) 

def s_wavelength(s_omega, w_0):
    a = wavelength(w_0) 
    b = wavelength(w_0 + s_omega)
    return abs(b - a) 

#define a gaussian distribution
#accepts x (1D array-like)
#x_0 (value)
#and s (value)
#and returns a gaussian distribution in 'x' centered around x_0 with bandwidth 's' 
def gauss(x, x_0, s):
    a = x - x_0 
    b = 2 * s**2 
    gauss = np.exp(-a**2 / b) 
    return gauss 
    
#this calculates the overlap integral between two 2D joint spectral amplitudes {JSA_1, JSA_2} (2D array-like)
#by taking the integral of their product over {l_1, l_2} (1D array-like)
#this function returns a single value (overlap) 
def get_overlap_2D(l_1, l_2, JSA_1, JSA_2, title_1, title_2):
    #normalize the two input spectra and take the conjugate of one of them
    JSA_1 = np.conjugate(normalize_2D(l_1, l_2, JSA_1))
    JSA_2 = normalize_2D(l_1, l_2, JSA_2) 
    #define a pseudo-differential for the discrete integral
    dl_1 = (l_1[-1] - l_1[0]) / len(l_1)
    dl_2 = (l_2[-1] - l_2[0]) / len(l_2) 
    #define an integrand
    overlap_integrand = JSA_1 * dl_1 * JSA_2 * dl_2 
    #sum the integrand over all values
    overlap_integral = np.sum(overlap_integrand) 
    overlap = abs(overlap_integral) 
    print('The overlap between', title_1, 'and', title_2, 'is', overlap)
    return overlap 

#Sellmeier equations for crystal options
#Source: refractiveindex.info
#ordinary (o) and extraordinary (e) refractive indices of different crystals as a fucntion of wavelength in um
#the notation 'f = lambda x: f(x)' is the same as 'def f(x): return f(x)' in Python 
#these functions take x (corresponding to wavelength in micrometers) and return a refractive index value
n_x_KTP = lambda x: (3.29100+0.04140/(x**2-0.03978)+9.35522/(x**2-31.45571))**.5
n_z_KTP = lambda x: (4.59423+0.06206/(x**2-0.04763)+110.80672/(x**2-86.12171))**.5
n_y_KTP = lambda x: (3.45018+0.04341/(x**2-0.04597)+16.98825/(x**2-39.43799))**.5
n_o_LNO3 = lambda x: (1+2.6734/(1-0.01764/x**2)+1.2290/(1-0.05914/x**2)+12.614/(1-474.60/x**2))**.5
n_e_LNO3 = lambda x: (1+2.9804/(1-0.02047/x**2)+0.5981/(1-0.0666/x**2)+8.9543/(1-416.08/x**2))**.5
n_o_BBO = lambda x: (2.7405+0.0184/(x**2-0.0179)-0.0155*x**2)**.5
n_e_BBO = lambda x: (2.3730+0.0128/(x**2-0.0156)-0.0044*x**2)**.5
n_o_AgGaS2 = lambda x: (5.7975+0.2311/(x**2-0.0688)-0.00257*x**2)**.5
n_e_AgGaS2 = lambda x: (5.5436+0.2230/(x**2-0.0946)-0.00261*x**2)**.5 

